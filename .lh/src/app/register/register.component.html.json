            "date": 1784102949997,
            "name": "Commit-0",
            "content": "<div class=\"container\">\r\n  <h2>Register</h2>\r\n  <form (ngSubmit)=\"savReq()\" #registerForm=\"ngForm\">\r\n    <div class=\"form-group\">\r\n      <label for=\"name\">Username</label>\r\n      <input type=\"text\" class=\"form-control\" id=\"name\" required minlength=\"3\" [(ngModel)]=\"user.name\" name=\"name\">\r\n    </div>\r\n    <div class=\"form-group\">\r\n      <label for=\"email\">Email</label>\r\n      <input type=\"email\" class=\"form-control\" id=\"email\" required [(ngModel)]=\"user.email\" name=\"email\">\r\n    </div>\r\n    <div class=\"form-group\">\r\n      <label for=\"password\">Password</label>\r\n      <input type=\"password\" class=\"form-control\" id=\"password\" required minlength=\"6\" [(ngModel)]=\"user.password\" name=\"password\">\r\n    </div>\r\n    <div class=\"form-group\">\r\n      <label for=\"role\">Role</label>\r\n      <select class=\"form-control\" id=\"role\" [(ngModel)]=\"user.role\" name=\"role\">\r\n        <option value=\"USER\">User</option>\r\n        <option value=\"HR_MANAGER\">HR Manager</option>\r\n        <option value=\"ADMIN\">Admin</option>\r\n      </select>\r\n    </div>\r\n    <button type=\"submit\" class=\"btn btn-primary\" [disabled]=\"!registerForm.form.valid\">Register</button>\r\n    <div *ngIf=\"errorMessage\" class=\"alert alert-danger mt-3\">\r\n      {{ errorMessage }}\r\n    </div>\r\n    <div *ngIf=\"successMessage\" class=\"alert alert-success mt-3\">\r\n      {{ successMessage }}\r\n    </div>\r\n  </form>\r\n</div>\r\n"
        }
    ]
}